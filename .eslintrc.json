{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 12
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-empty": "warn"
  },
  "ignorePatterns": [
    "core/*.js",
    "plugins/utils/misc.js",
    "plugins/utils/yt.js",
    "plugins/utils/manglish.js",
    "node_modules/"
  ]
}